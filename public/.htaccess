RewriteEngine On

# Block access to hidden files
RewriteRule (^|/)\.(?!well-known) - [F]

# Route everything through index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]

# Block .env files
<Files ".env">
    Require all denied
</Files>
